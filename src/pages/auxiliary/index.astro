---
// Auxiliary addon — lighter presets and embed-friendly params.
// Served at <mount-path>/auxiliary/ — e.g. https://yoursite.com/wave/auxiliary/
// URL params (read client-side): ?controls=0  ?preset=Essex  ?bg=transparent
// Hash form also supported: #controls=0&preset=Essex
// Static client-only shell — prerender to HTML (no per-request SSR needed).
export const prerender = true;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Essex Wave Auxiliary</title>
    <style is:global>
      * { margin: 0; padding: 0; outline: none !important; box-sizing: border-box; }
      html, body, #root { width: 100%; height: 100%; overflow: hidden; background: #000; }
      canvas { display: block; outline: none !important; }
      #canvas { position: absolute; top: 0; left: 0; }
    </style>
  </head>
  <body>
    <div id="root"></div>
    <script>
      import '../../scripts/auxiliary.js';
    </script>
  </body>
</html>
