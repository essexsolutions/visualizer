---
// Main Essex Wave visualizer (Omma).
// Served at <mount-path>/ — e.g. https://yoursite.com/wave/
// URL params (read client-side): ?controls=0|1  ?preset=Essex64L  ?fps=true
// SSR (not prerendered): Webflow Cloud strips trailing slashes, while Cloudflare's
// static-asset handler auto-adds them to a prerendered /wave/index.html — the two
// fight in a redirect loop. Serving the shell via the worker avoids that.
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Essex Wave Production</title>
    <style is:global>
      * { margin: 0; padding: 0; outline: none !important; box-sizing: border-box; }
      html, body, #root { width: 100%; height: 100%; overflow: hidden; background: #000; }
      canvas { display: block; outline: none !important; }
      #canvas { position: absolute; top: 0; left: 0; }
    </style>
  </head>
  <body>
    <div id="root"></div>
    <script>
      import '../scripts/main.js';
    </script>
  </body>
</html>
